# ============================================================
# 2. DIAGNOSTIC TESTS ON STANDARDIZED RESIDUALS
# ============================================================
# z_t = residual_t / conditional sigma_t
#
# We test:
# - Ljung-Box on standardized residuals: remaining linear autocorrelation
# - Ljung-Box on squared standardized residuals: remaining volatility dependence
# - ARCH LM test on standardized residuals: remaining ARCH effects

diagnostic_results <- data.frame()

for (company in names(selected_fits)) {
  
  fit <- selected_fits[[company]]
  z <- residuals(fit, standardize = TRUE)
  z <- as.numeric(z)
  z <- na.omit(z)
  
  lb_z_10  <- Box.test(z, lag = 10, type = "Ljung-Box")
  lb_z_20  <- Box.test(z, lag = 20, type = "Ljung-Box")
  
  lb_z2_10 <- Box.test(z^2, lag = 10, type = "Ljung-Box")
  lb_z2_20 <- Box.test(z^2, lag = 20, type = "Ljung-Box")
  
  arch_5   <- FinTS::ArchTest(z, lags = 5)
  arch_10  <- FinTS::ArchTest(z, lags = 10)
  
  diagnostic_results <- rbind(
    diagnostic_results,
    
    data.frame(
      Company = company,
      Test = "Ljung-Box standardized residuals",
