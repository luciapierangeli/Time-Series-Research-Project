read_stock <- function(filename) {
  df <- read_xls(filename, skip = 3, col_names = TRUE)
  
  # Keep only the relevant columns
  df <- df[, c("Date", "Close")]
  
  # Convert variables
  df$Date  <- as.Date(df$Date)
  df$Close <- as.numeric(df$Close)
  
  # Remove missing values and order by date
  df <- na.omit(df)
  df <- df[order(df$Date), ]
  
  return(df)
}

