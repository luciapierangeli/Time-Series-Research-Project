# ============================================================
# 2. FUNCTION TO FIT ONE GARCH MODEL
# ============================================================
# This function estimates a GARCH-type model and returns the fit.
# tryCatch is used because some models may fail to converge.

fit_garch_model <- function(r, arma_order = c(0, 0),
                            garch_order = c(1, 1),
                            model_type = "sGARCH",
                            distribution = "norm") {
  
  spec <- ugarchspec(
    variance.model = list(
      model = model_type,
      garchOrder = garch_order
    ),
    mean.model = list(
      armaOrder = arma_order,
      include.mean = TRUE
    ),
    distribution.model = distribution
  )
  
  fit <- tryCatch(
    ugarchfit(
      spec = spec,
      data = r,
      solver = "hybrid"
    ),
    error = function(e) NULL
  )
  
  return(fit)
}

# ============================================================
# 3. DEFINE CANDIDATE MODELS
# ============================================================
# sGARCH = standard GARCH
# gjrGARCH = asymmetric GARCH model
# eGARCH = exponential GARCH model
#
# Normal and Student-t distributions are compared because
# financial returns often have heavy tails.

candidate_models <- list(
  
  # Standard GARCH models with constant mean
  list(name = "sGARCH(1,1)-norm", arma = c(0,0), garch = c(1,1), model = "sGARCH", dist = "norm"),
  list(name = "sGARCH(1,1)-std",  arma = c(0,0), garch = c(1,1), model = "sGARCH", dist = "std"),
  
  list(name = "sGARCH(1,2)-std",  arma = c(0,0), garch = c(1,2), model = "sGARCH", dist = "std"),
  list(name = "sGARCH(2,1)-std",  arma = c(0,0), garch = c(2,1), model = "sGARCH", dist = "std"),
  list(name = "sGARCH(2,2)-std",  arma = c(0,0), garch = c(2,2), model = "sGARCH", dist = "std"),
  
  # Asymmetric GARCH-type models
  list(name = "gjrGARCH(1,1)-std", arma = c(0,0), garch = c(1,1), model = "gjrGARCH", dist = "std"),
  list(name = "eGARCH(1,1)-std",   arma = c(0,0), garch = c(1,1), model = "eGARCH",   dist = "std"),
  
  # ARMA-GARCH models, useful especially for GALP because
  # the Ljung-Box test suggested autocorrelation in returns.
  list(name = "AR(1)-sGARCH(1,1)-std",    arma = c(1,0), garch = c(1,1), model = "sGARCH", dist = "std"),
  list(name = "MA(1)-sGARCH(1,1)-std",    arma = c(0,1), garch = c(1,1), model = "sGARCH", dist = "std"),
  list(name = "ARMA(1,1)-sGARCH(1,1)-std", arma = c(1,1), garch = c(1,1), model = "sGARCH", dist = "std")
)

# ============================================================
# 4. FIT ALL CANDIDATE MODELS FOR EACH COMPANY
# ============================================================

all_fits <- list()
model_selection <- data.frame()

for (company in names(returns_list)) {
  
  cat("\n============================================================\n")
  cat("FITTING MODELS FOR:", company, "\n")
  cat("============================================================\n")
  
  r <- returns_list[[company]]
  company_fits <- list()
  
  for (m in candidate_models) {
    
    cat("Estimating:", m$name, "\n")
    
    fit <- fit_garch_model(
      r = r,
      arma_order = m$arma,
      garch_order = m$garch,
      model_type = m$model,
      distribution = m$dist
    )
    
    company_fits[[m$name]] <- fit
    
    if (!is.null(fit)) {
      
      ic <- infocriteria(fit)
      
      model_selection <- rbind(
        model_selection,
        data.frame(
          Company = company,
          Model = m$name,
          AIC = as.numeric(ic[1]),
          BIC = as.numeric(ic[2]),
          Shibata = as.numeric(ic[3]),
          HannanQuinn = as.numeric(ic[4]),
          Convergence = fit@fit$convergence
        )
      )
      
    } else {
      
      model_selection <- rbind(
        model_selection,
        data.frame(
          Company = company,
          Model = m$name,
          AIC = NA,
          BIC = NA,
          Shibata = NA,
          HannanQuinn = NA,
          Convergence = NA
        )
      )
    }
  }
  
  all_fits[[company]] <- company_fits
}

